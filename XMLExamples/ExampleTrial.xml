<?xml version="1.0" encoding="utf-8"?>
<!--
    KernelExtensions 试炼配置文件示例
    文件名：ExampleTrial.xml
    放置位置：扩展根目录/Trial/ExampleTrial.xml
    使用方法：通过添加 Flag "CustomTrial_ExampleTrial" 来加载此配置

    == 可选项默认行为 / Default behavior for optional fields ==
    - 如果不希望使用某个功能，通常直接省略对应的 XML 元素即可。
      If you do not want to use a feature, simply omit the corresponding XML element.
    - 对于数值型：省略或设为 0 表示禁用（如 <Timeout>0</Timeout>）。
      For numeric values: omit or set to 0 to disable (e.g., <Timeout>0</Timeout>).
    - 对于布尔型：省略或设为 false 表示禁用（如 <EnableFlickering>false</EnableFlickering>）。
      For boolean values: omit or set to false to disable (e.g., <EnableFlickering>false</EnableFlickering>).
    - 对于音乐/文件路径：省略或留空表示不播放/不执行。
      For music/file paths: omit or leave empty to mean no music / no action.
    - 对于动作文件引用（如 OnStart, OnComplete, OnFail, OnPhaseStart）：省略即不执行任何动作。
      For action file references (e.g., OnStart, OnComplete, OnFail, OnPhaseStart): omit to execute no action.
    - 对于颜色配置：省略或留空则使用当前游戏主题的对应颜色（如高亮色）。
      For color settings: omit or leave empty to use the current theme's highlight color.
    - 对于内存缩减配置：省略则使用默认值（延迟5秒，持续时间3秒）。
      For RAM reduction settings: omit to use defaults (delay 5s, duration 3s).
-->

<TrialConfig>
	<!-- ==================== 基础信息 ==================== -->
	<!-- ==================== Basic Info ==================== -->

	<!-- 程序在 ps 命令中显示的名称（可选，默认 "CustomTrial"） -->
	<!-- Name displayed in the 'ps' command output (optional, defaults to "CustomTrial"). -->
	<ProgramName>CustomTrial</ProgramName>

	<!-- ==================== 动作文件引用 ==================== -->
	<!-- ==================== Action File References ==================== -->

	<!-- 点击“开始试炼”后立即执行的动作文件（可选） -->
	<!-- Action file executed immediately after clicking "Begin Trial" (optional). -->
	<OnStart file="Actions/OnStart.xml" />

	<!-- 所有动画完成后执行的动作文件（可选） -->
	<!-- Action file executed after all animations complete (optional). -->
	<OnAnimationComplete file="Actions/TrialStart.xml" />

	<!-- 全局超时失败时执行的动作文件（可选） -->
	<!-- Action file to execute on global timeout failure (optional). -->
	<OnGlobalFail file="Actions/GlobalFail.xml" />

	<!-- 所有阶段完成后的最终动作（可选） -->
	<!-- Final action after all phases are completed (optional). -->
	<OnComplete file="Actions/AllComplete.xml" />

	<!-- ==================== 动画与特效配置 ==================== -->
	<!-- ==================== Animation & Effects ==================== -->

	<!-- 旋转动画时长（秒），默认 13.8 -->
	<!-- Spin animation duration (seconds). Defaults to 13.8. -->
	<SpinUpDuration>5.0</SpinUpDuration>

	<!-- 是否启用 UI 闪烁+节点消失特效，默认 true -->
	<!-- Enable UI flickering + node disappearance effect. Defaults to true. -->
	<EnableFlickering>true</EnableFlickering>

	<!-- 闪烁特效持续时间（秒），仅当 EnableFlickering=true 时生效，默认 10 -->
	<!-- Duration of flickering effect (seconds). Only applies when EnableFlickering=true. Defaults to 10. -->
	<FlickeringDuration>8.0</FlickeringDuration>

	<!-- 是否允许摧毁节点，默认 true -->
	<!-- Whether to allow node destruction. Defaults to true. -->
	<EnableNodeDestruction>true</EnableNodeDestruction>

	<!-- 节点摧毁完成后、邮件爆炸前的等待秒数，默认 0 -->
	<!-- Delay in seconds after node destruction before mail icon explosion. Default 0. -->
	<PostDestructionDelay>1.5</PostDestructionDelay>

	<!-- 是否启用邮件图标爆炸特效，默认 true -->
	<!-- Enable mail icon explosion effect. Defaults to true. -->
	<EnableMailIconDestroy>false</EnableMailIconDestroy>

	<!-- 邮件爆炸持续时间（秒），默认 3.82 -->
	<!-- Duration of mail explosion effect (seconds). Defaults to 3.82. -->
	<MailIconDestroyDuration>4.5</MailIconDestroyDuration>

	<!-- 邮件图标爆炸时是否将终端外区域变暗（聚焦效果） -->
	<!-- Whether to darken the area outside the terminal during mail icon explosion. -->
	<MailPhaseDarkenEnabled>true</MailPhaseDarkenEnabled>

	<!-- ==================== 终端聚焦特效 ==================== -->
	<!-- ==================== Terminal Focus Effects ==================== -->

	<!-- 阶段开始时是否显示终端聚焦特效（全屏变暗 + 边框扩散） -->
	<!-- Whether to show terminal focus effect (darken outside + expanding border) when a phase starts. -->
	<EnablePhaseStartFocus>true</EnablePhaseStartFocus>

	<!-- 试炼完成时是否显示终端聚焦特效 -->
	<!-- Whether to show terminal focus effect when the trial completes. -->
	<EnableTrialCompleteFocus>true</EnableTrialCompleteFocus>

	<!-- ==================== 音乐配置 ==================== -->
	<!-- ==================== Music Settings ==================== -->

	<!-- 程序启动后、点击“开始试炼”前的背景音乐 -->
	<!-- Background music after program start but before clicking "Start Trial". -->
	<StartMusic>Music/Ambient/dark_drone_008</StartMusic>

	<!-- 点击“开始试炼”后播放的音乐 -->
	<!-- Music played after clicking "Start Trial". -->
	<TrialStartMusic>DLC/Music/snidelyWhiplash</TrialStartMusic>

	<!-- ==================== 主题切换配置 ==================== -->
	<!-- ==================== Theme Switching ==================== -->

	<!-- 要切换的主题：预设名称或自定义主题文件路径，留空则不切换 -->
	<!-- Theme to switch to: preset name or custom theme file path. Omit to disable. -->
	<ThemeToSwitch>HacknetMint</ThemeToSwitch>

	<!-- 主题切换时的闪烁时长（秒），默认 2 -->
	<!-- Flicker duration when switching theme (seconds). Defaults to 2. -->
	<ThemeFlickerDuration>2.0</ThemeFlickerDuration>

	<!-- ==================== 自定义颜色 ==================== -->
	<!-- ==================== Custom Colors ==================== -->

	<!-- 程序窗口背景颜色（支持名称、#RRGGBB，或 LDTchara 彩虹色） -->
	<!-- Background color of the program window (name, #RRGGBB, or LDTchara). -->
	<BackgroundColor>#1a1a2e</BackgroundColor>

	<!-- 全局进度条颜色 -->
	<!-- Global timer bar color. -->
	<GlobalTimerColor>LDTchara</GlobalTimerColor>

	<!-- 阶段进度条颜色 -->
	<!-- Phase timer bar color. -->
	<PhaseTimerColor>#00ffcc</PhaseTimerColor>

	<!-- 旋转动画颜色 -->
	<!-- Spin animation color. -->
	<SpinUpColor>#ffaa44</SpinUpColor>

	<!-- ==================== 内存缩减配置 ==================== -->
	<!-- ==================== RAM Reduction ==================== -->

	<!-- 进入破解阶段后延迟多少秒开始缩减内存，默认 5 -->
	<!-- Delay (seconds) after entering the cracking phase before starting RAM reduction. Default 5. -->
	<RamReductionDelay>5.0</RamReductionDelay>

	<!-- 缩减内存所需的总秒数，默认 3 -->
	<!-- Duration (seconds) of the RAM reduction process. Default 3. -->
	<RamReductionDuration>3.0</RamReductionDuration>

	<!-- 是否启用动态内存缩减：根据窗口内实际控件高度自动调整 ramCost，默认 false 
	启用时会忽略上面的两个属性，建议设为 true 以避免视觉上的错误。-->
	<!-- Whether to enable dynamic RAM reduction. Defaults to false. 
	When enabled, the above two properties will be ignored. It is recommended to set it to true to avoid visual errors.-->
	<DynamicRamReduction>true</DynamicRamReduction>

	<!-- ==================== 全局计时器 ==================== -->
	<!-- ==================== Global Timer ==================== -->

	<!-- 整个试炼的总时限（秒），0 表示无限制 -->
	<!-- Total time limit for the entire trial (seconds). 0 means no limit. -->
	<GlobalTimeout>300</GlobalTimeout>

	<!-- 是否显示全局倒计时条，默认 false -->
	<!-- Whether to show the global countdown bar. Defaults to false. -->
	<EnableGlobalTimer>true</EnableGlobalTimer>

	<!-- ==================== 阶段计时器显示开关 ==================== -->
	<!-- ==================== Phase Timer Display ==================== -->

	<!-- 是否显示阶段倒计时条，默认 true -->
	<!-- Whether to show the phase countdown bar. Defaults to true. -->
	<EnablePhaseTimer>true</EnablePhaseTimer>

	<!-- ==================== 完成描述文本 ==================== -->
	<!-- ==================== Outro Text ==================== -->

	<!-- 试炼完成时显示在终端的描述文本（文件路径或内嵌文本），支持 % 停顿 -->
	<!-- Text displayed in terminal upon trial completion (file path or inline), supports % pause. -->
	<OutroText>Docs/TrialComplete.txt</OutroText>

	<!-- 试炼完成后自动连接的目标节点 ID（留空或省略则不转连） -->
	<!-- Target node ID to connect after trial completion. Omit or leave empty to disable. -->
	<ConnectTarget>dhs</ConnectTarget>

	<!-- 转连前是否停止音乐，默认 true -->
	<!-- Whether to stop music before connecting. Defaults to true. -->
	<StopMusicOnConnect>true</StopMusicOnConnect>


	<!-- ==================== 阶段列表 ==================== -->
	<!-- ==================== Phases ==================== -->
	<Phases>
		<!-- 第一阶段 -->
		<!-- Phase 0 -->
		<Phase id="0">
			<!-- 阶段标题（显示在程序窗口中央，必填） -->
			<!-- Phase title (displayed in the center of the program window, required). -->
			<Title>第一阶段：入侵 Gibson</Title>
			<!-- 阶段副标题（显示在标题下方，可选） -->
			<!-- Phase subtitle (displayed below the title, optional). -->
			<Subtitle>获取 root 权限并删除日志</Subtitle>

			<!-- 
                描述文本：可以是文件路径（相对于扩展根目录），也可以是直接内嵌的文本。
                支持 % 表示短停顿（约 0.5 秒），%% 表示长停顿（约 2 秒）。
                如果文件不存在，则当作纯文本显示。
                例如：<DescriptionText>Docs/MyTrialDesc.txt</DescriptionText>
            -->
			<!--
                Description text: can be a file path (relative to extension root) or inline text.
                Supports % for short pause (~0.5 seconds) and %% for long pause (~2 seconds).
                If the file does not exist, it is treated as plain text.
                Example: <DescriptionText>Docs/MyTrialDesc.txt</DescriptionText>
            -->
			<DescriptionText>Docs/MyTrialDesc.txt</DescriptionText>

			<!-- 任务文件路径（相对于扩展根目录），必填 -->
			<!-- Mission file path (relative to extension root), required. -->
			<MissionFile>Missions/ExampleMission1.xml</MissionFile>

			<!-- 
                阶段超时秒数（0 表示无超时）。如果大于 0，则在该阶段会启动阶段计时器。
                超时后根据 EnableResetOnFail 决定是重置阶段还是直接退出。
            -->
			<!--
                Phase timeout in seconds (0 means no timeout). If >0, the phase timer starts.
                After timeout, the behavior depends on EnableResetOnFail: reset phase or exit.
            -->
			<Timeout>120</Timeout>

			<!-- 本阶段专用的背景音乐（可选，覆盖全局音乐） -->
			<!-- Phase-specific background music (optional, overrides global music). -->
			<Music>Music/Ambient/AmbientDrone_Clipped</Music>

			<!-- 阶段开始时执行的动作文件 -->
			<!-- Action file to execute when the phase starts. -->
			<OnPhaseStart file="Actions/Phase0Start.xml" />

			<!-- 阶段完成时执行的动作文件（可选） -->
			<!-- Action file to execute on phase completion (optional). -->
			<OnComplete file="Actions/Phase0Complete.xml" />

			<!-- 阶段失败时执行的动作文件（可选，超时或追踪超时触发） -->
			<!-- Action file to execute on phase failure (optional, triggered by timeout or trace timeout). -->
			<OnFail file="Actions/Phase0Fail.xml" />

			<!-- 
                失败后是否重置当前阶段（重新开始本阶段，而不是退出）。
                可选值 true/false，默认 false。
                如果设为 true，则超时或追踪超时后会重新输出描述文本、重新加载任务、重置阶段计时器（全局计时器不受影响）。
            -->
			<!--
                Whether to reset the current phase on failure (restart the phase instead of exiting).
                Values: true/false, defaults to false.
                If true, on timeout or trace timeout it will re-print the description, reload the mission, and reset the phase timer (global timer unaffected).
            -->
			<EnableResetOnFail>true</EnableResetOnFail>
			
			<!-- 阶段失败重置时额外显示的文本（文件路径或内嵌文本），可选，支持 % 停顿 -->
			<!-- Extra text displayed when the phase is reset on failure (file path or inline), optional, supports % pauses. -->
			<ResetText>Docs/Phase0Reset.txt</ResetText>

			<!-- 阶段重置时是否再次执行 OnPhaseStart 动作，默认 false -->
			<!-- Whether to execute OnPhaseStart action again when the phase is reset. Defaults to false. -->
			<ExecuteOnPhaseStartOnReset>true</ExecuteOnPhaseStartOnReset>
		</Phase>

		<!-- 第二阶段 -->
		<!-- Phase 1 -->
		<Phase id="1">
			<Title>第二阶段：清除痕迹</Title>
			<Subtitle>删除所有操作记录</Subtitle>
			<DescriptionText>Docs/MyTrialDesc2.txt</DescriptionText>
			<MissionFile>Missions/ExampleMission2.xml</MissionFile>
			<Timeout>90</Timeout>
			<Music>Music/Ambient/dark_drone_008</Music>
			<OnPhaseStart file="Actions/Phase1Start.xml" />
			<OnComplete file="Actions/Phase1Complete.xml" />
			<OnFail file="Actions/Phase1Fail.xml" />
			<!-- 此阶段不重置（默认 false），超时后直接退出 -->
			<!-- This phase does not reset (default false), exits on timeout. -->
		</Phase>
	</Phases>

	<!-- 所有阶段完成后的最终动作（可选） -->
	<!-- Final action after all phases are completed (optional). -->
	<OnComplete file="Actions/AllComplete.xml" />
</TrialConfig>