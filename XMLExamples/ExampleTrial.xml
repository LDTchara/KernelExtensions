<?xml version="1.0" encoding="utf-8" ?>
<TrialConfig>
	<!-- 全局配置 -->
	<SpinUpDuration>5.0</SpinUpDuration>
	<!-- 旋转动画时长（秒） -->
	<EnableFlickering>false</EnableFlickering>
	<!-- 是否启用 UI 闪烁+节点消失特效 -->
	<EnableMailIconDestroy>false</EnableMailIconDestroy>
	<!-- 是否启用邮件图标爆炸特效 -->
	<StartMusic>Music/Ambient/dark_drone_008</StartMusic>
	<!-- 程序启动到点击按钮前的背景音乐 -->
	<TrialStartMusic>DLC/Music/snidelyWhiplash</TrialStartMusic>
	<!-- 点击“开始试炼”后播放的音乐 -->

	<!-- 阶段列表（按顺序执行） -->
	<Phases>
		<!-- 第一阶段 -->
		<Phase id="0">
			<Title>First Mission</Title>
			<Subtitle>Hack the Gibson</Subtitle>
			<!-- 描述文本：可以是文件路径（相对于游戏根目录）或直接写文本 -->
			<DescriptionText>Content/DLC/Docs/KaguyaTrial1.txt</DescriptionText>
			<!-- 任务文件路径（相对于游戏根目录） -->
			<MissionFile>Missions/ExampleMission1.xml</MissionFile>
			<!-- 超时时间（秒），0 表示无超时 -->
			<Timeout>120</Timeout>
			<!-- 本阶段专用的背景音乐（可选） -->
			<Music>Music/Ambient/AmbientDrone_Clipped</Music>
			<!-- 阶段完成时执行的动作（当前版本简化，仅输出文本；计划支持外部 Action 文件） -->
			<OnComplete file="Actions/Phase0Complete.xml" />
			<!-- 阶段失败时执行的动作 -->
			<OnFail file="Actions/Phase0Fail.xml" />
		</Phase>

		<!-- 第二阶段 -->
		<Phase id="1">
			<Title>Second Mission</Title>
			<Subtitle>Delete the logs</Subtitle>
			<DescriptionText>Content/DLC/Docs/KaguyaTrial2.txt</DescriptionText>
			<MissionFile>Missions/ExampleMission2.xml</MissionFile>
			<Timeout>90</Timeout>
			<Music>Music/Ambient/dark_drone_008</Music>
			<OnComplete file="Actions/Phase1Complete.xml" />
			<OnFail file="Actions/Phase1Fail.xml" />
		</Phase>
	</Phases>

	<!-- 所有阶段完成后的最终动作 -->
	<OnComplete file="Actions/AllComplete.xml" />
</TrialConfig>